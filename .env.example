# Copy to .env and fill in. The app runs in LOCAL-ONLY mode if these are absent:
# capture and offline persistence work, but nothing syncs to the backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Routing (no metered API) ---
# Routing is done by Claude (Max subscription) on a private GitHub repo — there is
# NO per-transaction Claude API cost. Set the private repo that exchanges captures
# and observations (the routing/ workspace). Optional: the copy/paste flow on the
# Routing screen needs none of this. The GitHub token is entered IN-APP and stored
# on-device only — never put it here.
# VITE_ROUTING_REPO=you/cairn-routing
# VITE_ROUTING_BRANCH=main
